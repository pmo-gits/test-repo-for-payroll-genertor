function glpBuildSpreadsheetUrl_(fileId) {
  return fileId ? `https://docs.google.com/spreadsheets/d/${fileId}/edit` : '';
}

function glpRequireHeaderIndex_(headerIndexMap, headerName, tabName) {
  const k = norm_(headerName);
  if (!headerIndexMap.has(k)) {
    throw new Error(`Header "${headerName}" not found in ${tabName}.`);
  }
  return headerIndexMap.get(k);
}
